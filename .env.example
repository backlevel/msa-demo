# ============================================================
# MSA Demo - 환경변수 설정
# 이 파일을 .env로 복사 후 실제 값 입력
# cp .env.example .env
# ============================================================

# Google Gemini API Key
# 발급: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Slack Bot Token
# 발급: https://api.slack.com/apps > Create App > Bot Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack 알림 채널
SLACK_CHANNEL=#customer-support
